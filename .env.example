# ─────────────────────────────────────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────────────────────────────────────
BASE_MODEL=microsoft/layoutlmv3-base
OCR_BACKEND=paddle          # "paddle" | "tesseract"
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false
LOG_LEVEL=INFO

# ─────────────────────────────────────────────────────────────────────────────
# Training
# ─────────────────────────────────────────────────────────────────────────────
EPOCHS=10
BATCH_SIZE=4
LEARNING_RATE=5e-5
SEED=42

# ─────────────────────────────────────────────────────────────────────────────
# MLOps (optional — leave blank to disable)
# ─────────────────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=
WANDB_PROJECT=
