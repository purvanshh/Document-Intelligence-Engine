DIE_PROJECT_NAME=layout-aware-document-intelligence-engine
DIE_ENVIRONMENT=local
DIE_DEBUG=false

DIE_API__HOST=0.0.0.0
DIE_API__PORT=8000
DIE_API__RELOAD=false
DIE_API__WORKERS=1
DIE_API__CORS_ORIGINS=http://localhost:3000,http://localhost:8000
DIE_API__MAX_UPLOAD_SIZE_MB=25

DIE_INGESTION__MAX_FILE_SIZE_MB=25
DIE_INGESTION__PDF_DPI=200
DIE_INGESTION__SUPPORTED_EXTENSIONS=.pdf,.png,.jpg,.jpeg

DIE_OCR__BACKEND=paddleocr
DIE_OCR__LANGUAGE=en
DIE_OCR__MIN_CONFIDENCE=0.50
DIE_OCR__USE_ANGLE_CLS=true
DIE_OCR__USE_GPU=false
DIE_OCR__DET_LIMIT_SIDE_LEN=960
DIE_OCR__SINGLETON_ENABLED=true
DIE_OCR__PADDLEOCR_MODEL_DIR=
DIE_OCR__TESSERACT_CMD=

DIE_MODEL__LAYOUTLMV3_MODEL_NAME=microsoft/layoutlmv3-base
DIE_MODEL__REVISION=main
DIE_MODEL__DEVICE=cpu
DIE_MODEL__MAX_SEQUENCE_LENGTH=512
DIE_MODEL__BATCH_SIZE=4

DIE_PREPROCESSING__TARGET_DPI=200
DIE_PREPROCESSING__MAX_IMAGE_SIDE=2048
DIE_PREPROCESSING__GRAYSCALE=false
DIE_PREPROCESSING__RESIZE_MAX_WIDTH=1600
DIE_PREPROCESSING__RESIZE_MAX_HEIGHT=1600
DIE_PREPROCESSING__NORMALIZE_PIXELS=true
DIE_PREPROCESSING__NOISE_REDUCTION=true
DIE_PREPROCESSING__DESKEW=false
DIE_PREPROCESSING__MEDIAN_BLUR_KERNEL_SIZE=3

DIE_LOGGING__LEVEL=INFO
DIE_LOGGING__JSON=true
DIE_LOGGING__SERVICE_NAME=layout-aware-document-intelligence-engine

DIE_PATHS__RAW_DIR=data/raw
DIE_PATHS__PROCESSED_DIR=data/processed
DIE_PATHS__ANNOTATIONS_DIR=data/annotations
DIE_PATHS__EXPERIMENT_DIR=experiments/runs
DIE_PATHS__ARTIFACT_DIR=experiments/artifacts
DIE_PATHS__UPLOAD_DIR=data/processed/uploads
