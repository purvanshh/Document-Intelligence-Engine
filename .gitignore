# ─────────────────────────────────────────────────────────────────────────────
# ML artefacts  — keep the dir structure, ignore binary blobs
# ─────────────────────────────────────────────────────────────────────────────
experiments/checkpoints/
experiments/logs/
*.pt
*.pth
*.bin
*.onnx
*.safetensors

# ─────────────────────────────────────────────────────────────────────────────
# Data — raw data should NOT be committed; use DVC / S3 instead
# ─────────────────────────────────────────────────────────────────────────────
data/raw/
data/processed/
data/annotations/
*.csv
*.json
!src/**/*.json       # allow small JSON fixtures inside src

# ─────────────────────────────────────────────────────────────────────────────
